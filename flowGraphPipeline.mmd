flowchart TD
    subgraph Input_Data ["Data Sources"]
        TrainCSV["Train.txt<br/>(Normal Traffic)"]
        ValCSV["Validation.txt<br/>(Normal Traffic)"]
        TestCSV["Test.txt<br/>(Mixed Traffic)"]
    end

    subgraph Main_Execution ["Main Execution (main.py)"]
        Start((Start))
        CheckModel{Model Exists?}
    end

    subgraph Dataset_Builder ["Dataset Builder (datasetbuilder.py)"]
        Load[Load Packets & Labels]
        Group["Group into Sequences<br/>(N_PACKETS)"]
        
        subgraph Preprocessing
            Tokenize[Tokenize Sequences]
            Mask["Apply Random Masking<br/>(For Training Only)"]
        end
        
        OutputData["Outputs:<br/>1. Raw Dataset (Text + Labels)<br/>2. Tokenized Dataset (Masked Inputs)"]
    end

    subgraph Training_Phase ["Training Phase (byt5training.py)"]
        InitTrainer[Initialize ByT5Trainer]
        TrainLoop["Fine-tune ByT5<br/>(Seq2Seq Reconstruction)"]
        SaveModel[Save Best Model]
    end

    subgraph Detection_Phase ["Anomaly Detector (anomalydetector.py)"]
        InitDetector[Load Model & Raw Datasets]
        
        subgraph Thresholding
            ReconVal[Reconstruct Validation Set]
            CalcThresh["Calculate Threshold<br/>(Mean + 3*Std)"]
        end
        
        subgraph Evaluation
            ReconTest[Reconstruct Test Set]
            CalcError[Compute MSE Error]
            Compare{Error > Threshold?}
        end
        
        Metrics[Calculate AUC & F1]
        Report[Save CSV Report]
    end

    %% Connections
    Start --> Load
    TrainCSV --> Load
    ValCSV --> Load
    TestCSV --> Load
    
    Load --> Group --> Tokenize --> Mask --> OutputData
    
    OutputData --> CheckModel
    
    CheckModel -- No --> InitTrainer
    InitTrainer --> TrainLoop --> SaveModel
    SaveModel --> InitDetector
    
    CheckModel -- Yes --> InitDetector
    
    InitDetector --> ReconVal --> CalcThresh
    CalcThresh --> ReconTest --> CalcError --> Compare
    Compare --> Metrics --> Report 